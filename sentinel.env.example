# Copy to /etc/sentinel/sentinel.env and chmod 600.

# systemd parses KEY=value (no export, no quotes required for simple values).



# Caddy JSON access log (must be readable by the service user). Must be the same file your sites write to
# (not only the admin API). If you only see localhost:2019 /load, LOG_PATH is wrong or the file has no site traffic yet.
# After rotation, old volume may live in all-access.log.1 (Sentinel tails the path below only).

LOG_PATH=/var/log/caddy/all-access.log



# Persistent data outside the app directory (survives redeploy when you replace /opt/sentinel).

# When set: default ban file is STATE_DIR/bans.json and default audit log is STATE_DIR/audit.jsonl

# (unless you set SENTINEL_BAN_LIST or SENTINEL_AUDIT_LOG). Add this path to ReadWritePaths if hardened.

SENTINEL_STATE_DIR=/var/lib/sentinel



# Optional: override ban list path. If you omit this key entirely and SENTINEL_STATE_DIR is set, bans use

# STATE_DIR/bans.json. If you set SENTINEL_BAN_LIST= with an empty value, no ban file is used.

# SENTINEL_BAN_LIST=/opt/sentinel/bans.json



# Optional: sync Linux firewall DROP rules (requires root or CAP_NET_ADMIN)

SENTINEL_IPTABLES=1

SENTINEL_IPTABLES_CHAIN=INPUT



# Replay the whole access log from byte 0 on each process start, then follow new lines (heavy on large files).

# The key must start at the beginning of the line (systemd ignores lines with a leading space before KEY).

# LOG_FROM_START=1



# HTTP Basic Auth for / /data /api/* (omit both to disable in-app auth; use nginx OAuth2 proxy instead if preferred)

SENTINEL_AUTH_USER=admin

SENTINEL_AUTH_PASSWORD=change-me-use-long-secret



# Optional: override audit log path. Empty/unset with SENTINEL_STATE_DIR uses STATE_DIR/audit.jsonl.

# SENTINEL_AUDIT_LOG=/var/log/sentinel/audit.log

# SENTINEL_AUDIT_DISABLE=1

